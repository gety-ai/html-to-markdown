test: $(TARGET)
	@if [ -n "$$MOCK_SERVER_URL" ]; then \
		./$(TARGET); \
	else \
		if [ ! -x "$(MOCK_SERVER_BIN)" ]; then \
			echo "mock-server binary not found at $(MOCK_SERVER_BIN); run: cargo build -p mock-server --release" >&2; \
			exit 1; \
