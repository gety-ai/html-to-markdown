{
	"name": "@kreuzberg/html-to-markdown-node",
	"version": "3.6.19",
	"description": "High-performance HTML to Markdown converter",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kreuzberg-dev/html-to-markdown.git"
	},
	"files": [
		"index.js",
		"index.d.ts",
		"*.node"
	],
	"main": "index.js",
	"types": "index.d.ts",
	"exports": {
		".": {
			"types": "./index.d.ts",
			"require": "./index.js",
			"default": "./index.js"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "npx --yes -p @napi-rs/cli@^3.6.2 napi build --platform --release",
		"artifacts": "npx --yes -p @napi-rs/cli@^3.6.2 napi artifacts",
		"prepublishOnly": "npx --yes -p @napi-rs/cli@^3.6.2 napi prepublish -t npm --skip-optional-publish"
	},
	"devDependencies": {
		"@napi-rs/cli": "^3.6.2"
	},
	"optionalDependencies": {
		"@kreuzberg/html-to-markdown-node-darwin-arm64": "3.6.19",
		"@kreuzberg/html-to-markdown-node-darwin-x64": "3.6.19",
		"@kreuzberg/html-to-markdown-node-linux-arm64-gnu": "3.6.19",
		"@kreuzberg/html-to-markdown-node-linux-arm64-musl": "3.6.19",
		"@kreuzberg/html-to-markdown-node-linux-x64-gnu": "3.6.19",
		"@kreuzberg/html-to-markdown-node-linux-x64-musl": "3.6.19",
		"@kreuzberg/html-to-markdown-node-win32-arm64-msvc": "3.6.19",
		"@kreuzberg/html-to-markdown-node-win32-x64-msvc": "3.6.19"
	},
	"napi": {
		"binaryName": "html-to-markdown-node",
		"packageName": "@kreuzberg/html-to-markdown-node",
		"targets": [
			"x86_64-unknown-linux-gnu",
			"aarch64-unknown-linux-gnu",
			"x86_64-unknown-linux-musl",
			"aarch64-unknown-linux-musl",
			"x86_64-apple-darwin",
			"aarch64-apple-darwin",
			"x86_64-pc-windows-msvc",
			"aarch64-pc-windows-msvc"
		]
	},
	"engines": {
		"node": ">= 18"
	}
}
