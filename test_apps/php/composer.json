{
  "name": "kreuzberg-dev/e2e-php",
  "description": "E2e tests for PHP bindings",
  "type": "project",
  "minimum-stability": "RC",
  "prefer-stable": true,
  "repositories": {
    "localphp": false
  },
  "require": {
    "kreuzberg-dev/html-to-markdown": ">=3.4.0-rc.43"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.1",
    "guzzlehttp/guzzle": "^7.0"
  },
  "autoload-dev": {
    "psr-4": {
      "HtmlToMarkdown\\E2e\\": "tests/"
    }
  },
  "scripts": {
    "test": "php run_tests.php"
  }
}
